{
  "doctype": "DocType",
  "name": "Muster Development Proposal",
  "module": "Muster",
  "autoname": "MST-DEV-.YYYY.-.#####",
  "title_field": "app",
  "track_changes": 1,
  "field_order": ["ask_turn", "app", "policy", "status", "requested_by", "requested_at", "request_id", "objective_secret", "objective_hash", "source_section", "source_revision", "source_status_hash", "allowed_paths_json", "allowed_paths_hash", "policy_revision_hash", "review_section", "reviewed_by", "reviewed_at", "generation_section", "patch_file", "patch_hash", "test_manifest_file", "changed_files_json", "generated_at", "failure_summary", "apply_section", "applied_by", "applied_at", "apply_evidence_hash", "deployment_status"],
  "fields": [
    {"fieldname": "ask_turn", "fieldtype": "Link", "label": "Ask Turn", "options": "Muster Ask Turn", "reqd": 1, "read_only": 1},
    {"fieldname": "app", "fieldtype": "Link", "label": "Registered App", "options": "Muster Development App", "reqd": 1, "read_only": 1, "in_list_view": 1},
    {"fieldname": "policy", "fieldtype": "Link", "label": "Policy", "options": "Muster Policy", "reqd": 1, "read_only": 1},
    {"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "Proposed\nApproved\nRejected\nQueued\nGenerating\nReady\nFailed\nApplied", "default": "Proposed", "reqd": 1, "read_only": 1, "in_list_view": 1},
    {"fieldname": "requested_by", "fieldtype": "Link", "label": "Requested By", "options": "User", "reqd": 1, "read_only": 1},
    {"fieldname": "requested_at", "fieldtype": "Datetime", "label": "Requested At", "reqd": 1, "read_only": 1},
    {"fieldname": "request_id", "fieldtype": "Data", "label": "Idempotency Key", "reqd": 1, "unique": 1, "read_only": 1},
    {"fieldname": "objective_secret", "fieldtype": "Password", "label": "Encrypted Objective", "reqd": 1, "hidden": 1, "read_only": 1},
    {"fieldname": "objective_hash", "fieldtype": "Data", "label": "Objective SHA-256", "reqd": 1, "read_only": 1},
    {"fieldname": "source_section", "fieldtype": "Section Break", "label": "Immutable Source Evidence"},
    {"fieldname": "source_revision", "fieldtype": "Data", "label": "Source Revision", "reqd": 1, "read_only": 1},
    {"fieldname": "source_status_hash", "fieldtype": "Data", "label": "Source Status SHA-256", "reqd": 1, "read_only": 1},
    {"fieldname": "allowed_paths_json", "fieldtype": "Code", "label": "Reviewed Allowed Paths", "options": "JSON", "reqd": 1, "read_only": 1},
    {"fieldname": "allowed_paths_hash", "fieldtype": "Data", "label": "Allowed Paths SHA-256", "reqd": 1, "read_only": 1},
    {"fieldname": "policy_revision_hash", "fieldtype": "Data", "label": "Policy Revision SHA-256", "reqd": 1, "read_only": 1},
    {"fieldname": "review_section", "fieldtype": "Section Break", "label": "Independent Review"},
    {"fieldname": "reviewed_by", "fieldtype": "Link", "label": "Reviewed By", "options": "User", "read_only": 1},
    {"fieldname": "reviewed_at", "fieldtype": "Datetime", "label": "Reviewed At", "read_only": 1},
    {"fieldname": "generation_section", "fieldtype": "Section Break", "label": "Verified Patch Artifacts"},
    {"fieldname": "patch_file", "fieldtype": "Attach", "label": "Reviewed Unified Patch", "read_only": 1},
    {"fieldname": "patch_hash", "fieldtype": "Data", "label": "Patch SHA-256", "read_only": 1},
    {"fieldname": "test_manifest_file", "fieldtype": "Attach", "label": "Test Manifest", "read_only": 1},
    {"fieldname": "changed_files_json", "fieldtype": "Code", "label": "Changed Files", "options": "JSON", "read_only": 1},
    {"fieldname": "generated_at", "fieldtype": "Datetime", "label": "Generated At", "read_only": 1},
    {"fieldname": "failure_summary", "fieldtype": "Small Text", "label": "Safe Failure Summary", "read_only": 1},
    {"fieldname": "apply_section", "fieldtype": "Section Break", "label": "Separate Source Apply Gate"},
    {"fieldname": "applied_by", "fieldtype": "Link", "label": "Applied By", "options": "User", "read_only": 1},
    {"fieldname": "applied_at", "fieldtype": "Datetime", "label": "Applied At", "read_only": 1},
    {"fieldname": "apply_evidence_hash", "fieldtype": "Data", "label": "Apply Evidence SHA-256", "read_only": 1},
    {"fieldname": "deployment_status", "fieldtype": "Select", "label": "Deployment", "options": "Not Requested\nBlocked - No Approved Registry\nReady for Separate Gate\nDeployed\nRolled Back", "default": "Not Requested", "read_only": 1}
  ],
  "permissions": [
    {"role": "Muster Administrator", "read": 1, "write": 1, "create": 1},
    {"role": "System Manager", "read": 1, "write": 1, "create": 1},
    {"role": "Muster Automation Manager", "read": 1, "create": 1},
    {"role": "Muster Auditor", "read": 1, "export": 1}
  ]
}
